# Application
APP_ENV=local
CORS_ORIGINS=http://localhost:3000

# Project database (ORM + Alembic)
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_NAME=bi_app
APP_DB_USER=postgres
APP_DB_PASSWORD=postgres
# Optional — leave empty to use PostgreSQL default schema (public)
APP_DB_SCHEMA=

# Encrypts user-provided warehouse passwords stored in app.data_sources
CREDENTIALS_SECRET=change-me-to-a-long-random-secret-string

# AI provider
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-or-v1-replace-with-your-key
LLM_MODEL=openai/gpt-oss-20b:free
LLM_MODEL_FALLBACK=google/gemma-4-31b-it:free
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
EMBEDDING_DIMENSIONS=2048

# Chat / RAG knobs (optional)
RAG_TOP_K=5
SQL_MAX_ATTEMPTS=3
WAREHOUSE_MAX_ROWS=500
CHAT_HISTORY_LIMIT=5

# Warehouse credentials are supplied via POST /api/data/connect (not stored here).
# schema_name is optional; omit to use the PostgreSQL connection default.
# Local demo warehouse schema: sales (see Makefile DEMO_WH_SCHEMA).
# Typical flow: POST /api/data/connect → POST /api/data/embed-schema → POST /api/chat

# CSV/Excel upload target (server writer + readonly query user for chat)
UPLOAD_WH_HOST=localhost
UPLOAD_WH_PORT=5433
UPLOAD_WH_DATABASE=bi_warehouse
UPLOAD_WH_USER=bi_uploader
UPLOAD_WH_PASSWORD=uploader_pass
UPLOAD_WH_QUERY_USER=bi_readonly
UPLOAD_WH_QUERY_PASSWORD=readonly_pass
UPLOAD_MAX_BYTES=10485760
UPLOAD_MAX_ROWS=50000
